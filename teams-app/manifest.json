{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.19/MicrosoftTeams.schema.json",
  "manifestVersion": "1.19",
  "version": "1.0.2",
  "id": "__BOT_APP_ID__",
  "developer": {
    "name": "CCS Technologies",
    "websiteUrl": "https://www.ccs-technologies.com",
    "privacyUrl": "https://www.ccs-technologies.com/privacy",
    "termsOfUseUrl": "https://www.ccs-technologies.com/terms"
  },
  "name": {
    "short": "Order_Insights Bot",
    "full": "Order_Insights Bot (files & charts)"
  },
  "description": {
    "short": "AI assistant that delivers files and charts in Teams",
    "full": "Chat with an Azure AI Foundry agent that can generate downloadable files (CSV, Excel) and render charts inline, delivered natively in Microsoft Teams."
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#2D7D9A",
  "bots": [
    {
      "botId": "__BOT_APP_ID__",
      "scopes": ["personal", "team", "groupChat"],
      "supportsFiles": false,
      "isNotificationOnly": false
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": ["token.botframework.com", "login.microsoftonline.com"],
  "webApplicationInfo": {
    "id": "__BOT_APP_ID__",
    "resource": "api://botid-__BOT_APP_ID__"
  }
}
