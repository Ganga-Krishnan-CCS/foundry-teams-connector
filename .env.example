# --- Foundry project ---
# From the Foundry portal project overview page:
#   https://<your-resource>.services.ai.azure.com/api/projects/<your-project>
FOUNDRY_PROJECT_ENDPOINT=
# The agent's NAME as shown in the Foundry portal (new surface references agents
# by name, not by an asst_... id).
FOUNDRY_AGENT_NAME=

# --- Azure Bot credentials (M365 Agents SDK convention) ---
# From the Azure Bot resource created by the "Publish to Teams" wizard
# (Configuration blade: Microsoft App ID; secret from its App Registration).
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__AUTHTYPE=ClientSecret
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTSECRET=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__TENANTID=

# --- Per-user Foundry identity (REQUIRED — the app refuses to start without it) ---
# Fabric's tool doc: service-principal/API-key auth is NOT supported — it only
# enforces row/table security when called with a signed-in USER's own token.
# There is NO shared-identity fallback on the live path (see README
# "Per-user identity / RLS"); a turn without a user token is refused.
#
# Values below are the LIVE-VERIFIED config (2026-07-16/17):
# - AZUREBOTOAUTHCONNECTIONNAME = the Azure Bot Service OAuth connection
#   ("Aadv2" provider) on the bot. Its scopes must be
#   api://botid-<bot-app-id>/access_as_user and its Token Exchange URL
#   api://botid-<bot-app-id> (no scope suffix — must equal the app's
#   Application ID URI, which is also the Teams manifest webApplicationInfo
#   resource).
# - OBOCONNECTIONNAME must be SERVICE_CONNECTION (the MSAL connection above,
#   which performs the on-behalf-of exchange) — NOT the Bot OAuth connection.
# - SCOPES must be https://ai.azure.com/.default: Foundry's /openai/v1 rejects
#   other audiences (401 "audience is incorrect"). Do NOT use the AML
#   18a66f5f.../user_impersonation scope here.
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__FOUNDRY__TYPE=UserAuthorization
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__FOUNDRY__SETTINGS__AZUREBOTOAUTHCONNECTIONNAME=TeamsSSO
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__FOUNDRY__SETTINGS__OBOCONNECTIONNAME=SERVICE_CONNECTION
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__FOUNDRY__SETTINGS__SCOPES=https://ai.azure.com/.default

# --- Relay identity for Foundry access (used by DefaultAzureCredential) ---
# Easiest: reuse the bot's app registration — same values as the three above.
# Requirement: that app must be granted the "Azure AI User" role on the Foundry
# resource (Portal: Foundry resource -> Access control (IAM) -> Add role
# assignment -> Azure AI User -> select the bot's app registration).
# In Azure (App Service/Container App) replace this with a managed identity.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- Blob storage (download links for generated files) ---
BLOB_CONN_STR=
BLOB_CONTAINER=agent-files
SAS_TTL_HOURS=1

# --- Tuning ---
# Raw image bytes above this size are delivered via blob+SAS URL instead of an
# inline base64 data URI (when blob is configured).
DATA_URI_MAX_BYTES=51200
PORT=3978

# --- Only for app_classic.py (classic asst_* agents) ---
# FOUNDRY_AGENT_ID=
# MicrosoftAppId=
# MicrosoftAppPassword=
# MicrosoftAppType=SingleTenant
# MicrosoftAppTenantId=
